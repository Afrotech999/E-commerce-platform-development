{
  "name": "modern-ecommerce-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "cd backend && npm run dev",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:api\"",
    // use npx to invoke the local vite binary instead of executing the file directly
    // this avoids &#34;permission denied&#34; errors in environments where the
    // executable bit isn&#39;t set (e.g. Vercel clones from Windows commits).
    "build": "npx vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@radix-ui/react-slider": "^1.3.6",
    "@tailwindcss/postcss": "^4.2.1",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.575.0",
    "motion": "^12.34.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sonner": "^2.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  },
  "postinstall": "chmod +x node_modules/.bin/vite || true"
}
